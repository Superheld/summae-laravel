{
    "name": "superheld/summae-laravel",
    "description": "Laravel adapter for summae-core: service provider, database persistence, migrations",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/superheld/summae",
    "keywords": ["accounting", "laravel", "database", "rechnungswesen", "doppik", "gobd"],
    "support": {
        "issues": "https://github.com/superheld/summae/issues",
        "source": "https://github.com/superheld/summae"
    },
    "require": {
        "php": ">=8.3",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "superheld/summae-core": "*"
    },
    "autoload": {
        "psr-4": {
            "Summae\\Laravel\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "laravel": {
            "providers": [
                "Summae\\Laravel\\SummaeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
